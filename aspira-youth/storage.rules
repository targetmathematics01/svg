rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isAdmin() {
      return isSignedIn()
        && (
          request.auth.token.email == 'thureinminn@gmail.com'
          || request.auth.token.email == 'thureinminnn2026@gmail.com'
          || firestore.exists(/databases/(default)/documents/admins/$(request.auth.token.email))
        );
    }

    function isSupportedBlogImage() {
      return request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    match /blog_images/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.auth.uid == userId
        && isSupportedBlogImage();
      allow delete: if isAdmin() && request.auth.uid == userId;
    }
  }
}
