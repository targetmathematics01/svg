rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thureinminn@gmail.com' ||
        request.auth.token.email == 'thureinminnn2026@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    function isOwner(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    // Blogs
    match /blogs/{blogId} {
      // Anyone can read blogs
      allow read: if true;
      // Only admins can create, update, or delete blogs
      allow create, update, delete: if isAdmin();

      // Blog Comments
      match /comments/{commentId} {
        // Anyone can read comments
        allow read: if true;
        // Registered users can create comments
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        // Authors and admins can delete comments
        allow update, delete: if isAdmin() || isOwner(resource.data.authorId);
      }
    }

    // Forums
    match /forums/{forumId} {
      // Anyone can read forums
      allow read: if true;
      // Registered users can create forums
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      // Authors and admins can update or delete forums
      allow update, delete: if isAdmin() || isOwner(resource.data.authorId);

      // Forum Comments
      match /comments/{commentId} {
        // Anyone can read comments
        allow read: if true;
        // Registered users can create comments
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        // Authors and admins can delete comments
        allow update, delete: if isAdmin() || isOwner(resource.data.authorId);
      }
    }
    // Admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Albums
    match /albums/{albumId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Videos
    match /videos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Allow users collection if it exists
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }
  }
}
